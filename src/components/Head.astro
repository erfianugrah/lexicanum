---
import type { Props } from '@astrojs/starlight/props';
import Default from '@astrojs/starlight/components/Head.astro';
import { Font } from 'astro:assets';
import D2Fullscreen from './D2Fullscreen.astro';
---

{/* Self-hosted IBM Plex via Astro Fonts API (configured in astro.config.mjs).
    Both faces are preloaded — they're used on every page, so the cost is
    paid once and the fallback-flash on first paint is avoided. */}
<Font cssVariable="--font-plex-sans" preload />
<Font cssVariable="--font-plex-mono" preload />

<Default {...Astro.props}><slot /></Default>
<D2Fullscreen />
